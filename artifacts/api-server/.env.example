# Required
DATABASE_URL=postgresql://user:password@host:5432/dbname
JWT_SECRET=your-secret-here-min-32-chars

# Required for Express standalone (not needed for Vercel serverless)
PORT=5000

# Optional — comma-separated list of allowed frontend origins
# If unset, all origins are allowed (not recommended for production)
CORS_ORIGINS=https://your-symposium.vercel.app,https://your-admin.vercel.app,https://your-portal.vercel.app

# Optional — Google Cloud Storage (for file/photo uploads)
GCS_BUCKET=your-bucket-name
GOOGLE_CLOUD_PROJECT=your-project-id
